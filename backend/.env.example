# Copy this file to .env and adjust values as needed.
# All of these have sane defaults in app/config.py — you only need a .env
# at all if you want to override something (e.g. point at Postgres).

HOST=0.0.0.0
PORT=8000
DEBUG=true

# SQLite by default. For production, swap to Postgres + PostGIS, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/vyuha
DATABASE_URL=sqlite:///./vyuha.db

# Comma-separated list of allowed frontend origins
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:4173
